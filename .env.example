# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server port (Railway/Render will set this automatically)
PORT=3000

# Model to use for agent calls (default: claude-sonnet-4-20250514)
# SESI_MODEL=claude-sonnet-4-20250514

# Logging level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# Log format: text (default) or json (for production/structured logging)
# LOG_FORMAT=text
